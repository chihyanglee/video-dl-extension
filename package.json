{
  "name": "video-dl-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "description": "MV3 Chrome extension: detect non-DRM HLS streams, preview, download as mp4 via ffmpeg.wasm",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "serve:test": "python3 -m http.server 8080 --directory test"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "fast-xml-parser": "^4.5.6",
    "hls.js": "^1.5.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@ffmpeg/core": "^0.12.6",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
